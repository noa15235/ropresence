{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoPresence",
  "version": "0.1.0",
  "identifier": "com.ropresence.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "RoPresence",
        "width": 980,
        "height": 660,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "libgcc_s_seh-1.dll",
      "libwinpthread-1.dll",
      "libstdc++-6.dll",
      "WebView2Loader.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
